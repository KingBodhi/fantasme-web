---
import Base from '../layouts/Base.astro';
---
<Base title="Cart — FANTASME⁺">
  <link slot="head" rel="stylesheet" href="/css/home.css" />
  <nav class="nav stuck" id="nav">
    <div class="nav-inner">
      <a href="/#shop" class="nav-brand">FANTASME<sup>+</sup></a>
      <ul class="nav-links">
        <li><a href="/new">New</a></li>
        <li><a href="/collections">Collections</a></li>
        <li><a href="/#shop">Shop</a></li>
        <li><a href="/archive.html">Archive</a></li>
        <li><a href="/lookbook.html">Lookbook</a></li>
      </ul>
      <div class="nav-util">
        <a href="/search">Search</a>
        <a href="/cart" style="opacity:1;color:var(--text)">Cart (0)</a>
      </div>
    </div>
  </nav>
  <div style="min-height:100vh;background:#04040c;padding-top:58px;max-width:760px;margin:0 auto;padding-left:24px;padding-right:24px;">
    <div style="padding:80px 0 40px;">
      <h1 style="font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:13px;font-weight:400;letter-spacing:0.32em;text-transform:uppercase;color:rgba(237,237,245,0.4);">Your Cart</h1>
    </div>
    <div style="border-top:1px solid rgba(237,237,245,0.08);padding:80px 0;text-align:center;">
      <p style="font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:14px;letter-spacing:0.08em;color:rgba(237,237,245,0.32);">Your cart is empty.</p>
      <a href="/#shop" style="display:inline-block;margin-top:28px;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:10px;font-weight:500;letter-spacing:0.3em;text-transform:uppercase;color:#ededf5;border-bottom:1px solid rgba(237,237,245,0.24);padding-bottom:3px;">Continue Shopping</a>
    </div>
  </div>
  <script is:inline src="/js/home.js"></script>
</Base>
