---
import Base from '../layouts/Base.astro';
---
<Base title="Collections — FANTASME⁺">
  <link slot="head" rel="stylesheet" href="/css/home.css" />
  <nav class="nav stuck" id="nav">
    <div class="nav-inner">
      <a href="/#shop" class="nav-brand">FANTASME<sup>+</sup></a>
      <ul class="nav-links">
        <li><a href="/new">New</a></li>
        <li><a href="/collections" style="opacity:1;color:var(--text)">Collections</a></li>
        <li><a href="/#shop">Shop</a></li>
        <li><a href="/archive.html">Archive</a></li>
        <li><a href="/lookbook.html">Lookbook</a></li>
      </ul>
      <div class="nav-util">
        <a href="/search">Search</a>
        <a href="/cart">Cart (0)</a>
      </div>
    </div>
  </nav>
  <div style="min-height:100vh;background:#04040c;display:flex;flex-direction:column;align-items:center;justify-content:center;padding-top:58px;">
    <p style="font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:10px;letter-spacing:0.36em;text-transform:uppercase;color:rgba(237,237,245,0.3);margin-bottom:24px;">SS26 — Drop 001</p>
    <h1 style="font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:clamp(28px,4vw,56px);font-weight:400;letter-spacing:0.14em;color:#ededf5;text-align:center;">Collections</h1>
    <p style="font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:13px;letter-spacing:0.08em;color:rgba(237,237,245,0.36);margin-top:20px;">Coming soon.</p>
  </div>
  <script is:inline src="/js/home.js"></script>
</Base>
