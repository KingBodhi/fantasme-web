  <!-- home.js handles nav sticky + category filtering -->
  <script is:inline src="/js/home.js"></script>

  <script is:inline>
    // If navigated here via /#shop (e.g. clicking logo from another page),
    // immediately jump to the shop section without replaying the animation.
    if (window.location.hash === '#shop') {
      var shopEl = document.getElementById('shop');
      if (shopEl) {
        requestAnimationFrame(function () {
          shopEl.scrollIntoView({ behavior: 'instant' });
        });
      }
    }
  </script>

  <script is:inline>
    // On this page the nav is hidden during the 600vh hero animation.
    // Use inline styles (highest specificity) so home.js class toggling can't bleed through.
    (function () {
      var nav = document.getElementById('nav');
      if (!nav) return;

      // Hide immediately — before any paint — so the nav never flashes
      nav.style.opacity = '0';
      nav.style.pointerEvents = 'none';
      nav.style.transition = 'opacity 0.5s ease';

      var HERO_HEIGHT = window.innerHeight * 6;

      function updateNav() {
        var past = window.scrollY >= HERO_HEIGHT * 0.9;
        if (past) {
          nav.style.opacity = '';
          nav.style.pointerEvents = '';
        } else {
          nav.style.opacity = '0';
          nav.style.pointerEvents = 'none';
        }
        nav.classList.toggle('post-hero', past);
        nav.classList.toggle('stuck', past && window.scrollY > HERO_HEIGHT);
        nav.classList.remove('reveal-mode');
      }

      window.addEventListener('scroll', updateNav, { passive: true });
      window.addEventListener('resize', function () {
        HERO_HEIGHT = window.innerHeight * 6;
        updateNav();
      }, { passive: true });
      updateNav();
    })();
  </script>
</Base>
