---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero/Hero.astro';
---

<Base title="FANTASME⁺">
  <link slot="head" rel="stylesheet" href="/css/home.css" />

  <style>
    /* Nav is invisible until the user scrolls past the hero */
    .nav {
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.5s ease, background 0.5s ease, border-color 0.5s ease;
    }
    .nav.post-hero {
      opacity: 1;
      pointer-events: auto;
    }

    /* Solid black wall behind all post-hero content so
       the fixed Three.js canvas never shows through */
    .shop-layer {
      position: relative;
      z-index: 2;
      background: #04040c;
    }

    /* Bridge gradient sits just above the canvas */
    .hero-bridge {
      position: relative;
      z-index: 2;
      height: 32vh;
      min-height: 80px;
      background: linear-gradient(to bottom, transparent, #04040c);
      pointer-events: none;
    }
  </style>

  <!-- ─── THREE.JS HERO ─────────────────────────────────────────── -->
  <Hero />

  <!-- ─── GRADIENT BRIDGE ───────────────────────────────────────── -->
  <div class="hero-bridge"></div>

  <!-- ─── STICKY NAV (hidden until post-hero) ──────────────────── -->
  <nav class="nav" id="nav">
    <div class="nav-inner">
      <a href="/#shop" class="nav-brand">FANTASME<sup>+</sup></a>
      <ul class="nav-links">
        <li><a href="/new">New</a></li>
        <li><a href="/collections">Collections</a></li>
        <li><a href="#shop">Shop</a></li>
        <li><a href="/archive.html">Archive</a></li>
        <li><a href="/lookbook.html">Lookbook</a></li>
      </ul>
      <div class="nav-util">
        <a href="/search" class="nav-search">Search</a>
        <a href="/cart" class="nav-cart">Cart (0)</a>
      </div>
      <button class="nav-hamburger" id="nav-hamburger" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- ─── MOBILE NAV DRAWER ────────────────────────────────────── -->
  <div class="nav-mobile" id="nav-mobile" aria-hidden="true">
    <div class="nav-mobile-inner">
      <a href="/new">New</a>
      <a href="/collections">Collections</a>
      <a href="#shop">Shop</a>
      <a href="/archive.html">Archive</a>
      <a href="/lookbook.html">Lookbook</a>
      <div class="nav-mobile-divider"></div>
      <a href="/search">Search</a>
      <a href="/cart">Cart (0)</a>
    </div>
  </div>

  <!-- ─── ALL SHOP CONTENT — solid black layer ─────────────────── -->
  <div class="shop-layer">

    <div class="marquee-band">
      <div class="marquee-track">
        <span>Drop 001 — Now Available</span><span class="sep">—</span>
        <span>SS26 Collection</span><span class="sep">—</span>
        <span>Free Shipping Over $250</span><span class="sep">—</span>
        <span>Limited Edition</span><span class="sep">—</span>
        <span>Drop 001 — Now Available</span><span class="sep">—</span>
        <span>SS26 Collection</span><span class="sep">—</span>
        <span>Free Shipping Over $250</span><span class="sep">—</span>
        <span>Limited Edition</span><span class="sep">—</span>
      </div>
    </div>

    <div class="cat-bar">
      <div class="cat-inner">
        <a href="#" class="cat active" data-filter="all">All</a>
        <a href="#" class="cat" data-filter="tees">Graphic Tees</a>
        <a href="#" class="cat" data-filter="tops">Tops</a>
        <a href="#" class="cat" data-filter="outerwear">Outerwear</a>
        <a href="#" class="cat" data-filter="bottoms">Bottoms</a>
        <a href="#" class="cat" data-filter="skirts">Skirts</a>
        <a href="/archive.html" class="cat">Archive</a>
      </div>
    </div>

    <section class="section shop" id="shop">
